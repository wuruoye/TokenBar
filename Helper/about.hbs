<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TokenBar third-party licenses</title>
    <style>
        :root { color-scheme: light dark; }
        body { font: 15px/1.5 -apple-system, BlinkMacSystemFont, sans-serif; margin: 0; }
        main { max-width: 860px; margin: 0 auto; padding: 32px 24px 64px; }
        h1 { margin-bottom: 8px; }
        h2 { margin-top: 32px; }
        a { color: #7864ff; }
        .licenses { list-style: none; padding: 0; }
        .license { border-top: 1px solid color-mix(in srgb, currentColor 18%, transparent); }
        pre { max-height: 320px; overflow: auto; padding: 16px; white-space: pre-wrap; background: color-mix(in srgb, currentColor 7%, transparent); border-radius: 10px; }
    </style>
</head>
<body>
<main>
    <h1>TokenBar third-party licenses</h1>
    <p>Generated from the locked Rust dependency graph for TokenBar's Universal 2 macOS helper.</p>

    <h2>Overview</h2>
    <ul>
        {{#each overview}}
        <li>{{name}} ({{count}})</li>
        {{/each}}
    </ul>

    <h2>License texts</h2>
    <ul class="licenses">
        {{#each licenses}}
        <li class="license">
            <h3>{{name}}</h3>
            <p>Used by:</p>
            <ul>
                {{#each used_by}}
                <li><a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">{{crate.name}} {{crate.version}}</a></li>
                {{/each}}
            </ul>
            <pre>{{text}}</pre>
        </li>
        {{/each}}
    </ul>
</main>
</body>
</html>
